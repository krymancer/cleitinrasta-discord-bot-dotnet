# Discord Bot Token (from Discord Developer Portal)
# This is the only required environment variable
DISCORD_TOKEN=your_discord_token_here

# Optional: Override Lavalink Configuration (defaults are set in appsettings.json)
# Uncomment these lines only if you need to override the defaults
# Lavalink__BaseAddress=http://lavalink:2333
# Lavalink__Passphrase=youshallnotpass

# Optional: Override Player Configuration (defaults are set in appsettings.json)
# Uncomment this line only if you need to override the default
# Player__InactivityTimeoutMinutes=5
