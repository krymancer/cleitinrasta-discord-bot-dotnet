# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_token_here

# Lavalink Configuration
# Base address for Lavalink server (use 'lavalink' for Docker, 'localhost' for local development)
Lavalink__BaseAddress=http://lavalink:2333
# Lavalink password (must match application.yml)
Lavalink__Passphrase=youshallnotpass

# Player Configuration
# Inactivity timeout in minutes before the bot disconnects from voice channel
Player__InactivityTimeoutMinutes=5
