<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Lavalink4NET.Integrations.Lavasearch" Version="4.2.0" />
      <PackageReference Include="Lavalink4NET.NetCord" Version="4.2.0" />
      <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
      <PackageReference Include="NetCord" Version="1.0.0-alpha.469" />
      <PackageReference Include="NetCord.Hosting" Version="1.0.0-alpha.469" />
      <PackageReference Include="NetCord.Hosting.Services" Version="1.0.0-alpha.469" />
    </ItemGroup>

    <ItemGroup>
      <None Update="appsettings.json">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
    </ItemGroup>

    <ItemGroup>
      <Compile Remove="Modules\SlashCommandModule.cs" />
    </ItemGroup>

</Project>
